{
  "module": {
    "name": "entry",
    "type": "entry",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "pages": "$profile:main_pages",
    "metadata": [
      {
        "name": "client_id",
        "value": "6917568345502278703"
      }
    ],
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "metadata": [
          {
            "name": "ohos.ability.shortcuts",
            "resource": "$profile:shortcuts_config"
          }
        ],
        "exported": true,
        "continuable": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          },
          {
            "entities": [
              "entity.system.default"
            ],
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "file",
                "type": "general.plain-text",
                "linkFeature": "FileOpen"
              },
              {
                "scheme": "file",
                "type": "general.comma-separated-values-text",
                "linkFeature": "FileOpen"
              },
              {
                "scheme": "storage",
                "path": "clearcache",
                "linkFeature": "AppStorageMgmt"
              }
            ]
          },
          {
            "entities": [
              "entity.system.default"
            ],
            "actions": [
              "ohos.want.action.sendData"
            ],
            "uris": [
              {
                "scheme": "file",
                "utd": "general.plain-text",
                "maxFileSupported": 1
              },
              {
                "scheme": "file",
                "utd": "general.comma-separated-values-text",
                "maxFileSupported": 1
              }
            ]
          },
          {
            "entities": [
              "entity.system.browsable"
            ],
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "https",
                "host": "www.zhangls2512.cn",
                "path": "product/password"
              }
            ],
            "domainVerify": true
          }
        ],
        "startWindowIcon": "$media:layered_image",
        "startWindowBackground": "$color:start_window_background",
        "removeMissionAfterTerminate": true,
        "orientation": "auto_rotation_restricted",
        "recoverable": true
      }
    ],
    "extensionAbilities": [
      {
        "name": "BackupExtensionAbility",
        "srcEntry": "./ets/BackupExtension/BackupExtension.ets",
        "type": "backup",
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      },
      {
        "name": "EntryFormAbility",
        "srcEntry": "./ets/entryformability/EntryFormAbility.ets",
        "type": "form",
        "metadata": [
          {
            "name": "ohos.extension.form",
            "resource": "$profile:form_config"
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.GET_NETWORK_INFO"
      },
      {
        "name": "ohos.permission.GET_WIFI_INFO"
      },
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.PRIVACY_WINDOW"
      },
      {
        "name": "ohos.permission.VIBRATE"
      },
      {
        "name": "ohos.permission.WINDOW_TOPMOST"
      },
      {
        "name": "ohos.permission.DISTRIBUTED_DATASYNC",
        "reason": "$string:DISTRIBUTED_DATASYNC_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      }
    ],
    "fileContextMenu": "$profile:menu",
    "routerMap": "$profile:router_map"
  }
}